<!DOCTYPE html>
<html>
<head>
  <title>LEGO Impressionist Generator</title>
  <link rel="stylesheet" href="styles.css">
</head>
<body>
  <h1>LEGO Mosaic Generator</h1>

  <input type="file" id="imageInput" accept="image/*">

  <div>
    Width (studs): <input type="number" id="width" value="50">
    Height (studs): <input type="number" id="height" value="50">
  </div>

  <button id="generateBtn">Generate</button>

  <canvas id="canvas" hidden></canvas>

  <div id="preview"></div>
  <div id="instructions"></div>

  <script src="script.js"></script>
</body>
</html>